generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://conductor:conductor@localhost:5432/conductor"
}

model Task {
  id          String         @id @default(uuid())
  goal        String
  status      TaskStatus     @default(PENDING)
  taskType    String?
  stepsJson   Json?
  resultJson  Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  logs        ExecutionLog[]
}

model ExecutionLog {
  id            String    @id @default(uuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  stepNumber    Int
  message       String
  screenshotB64 String?
  status        LogStatus @default(INFO)
  createdAt     DateTime  @default(now())
}

enum TaskStatus {
  PENDING
  PLANNING
  RUNNING
  COMPLETED
  FAILED
}

enum LogStatus {
  INFO
  SUCCESS
  ERROR
  SCREENSHOT
}
